rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email in ["brayuco03@gmail.com"];
    }

    function ownPatient(patientId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/patients/$(patientId)).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow create: if isSignedIn();
      allow read, update: if ownPatient(patientId) || isAdmin();
      allow delete: if isAdmin();

      match /clinics/{id} {
        allow read, write: if ownPatient(patientId) || isAdmin();
      }

      match /doctors/{id} {
        allow read, write: if ownPatient(patientId) || isAdmin();
      }

      match /companions/{id} {
        allow read, write: if ownPatient(patientId) || isAdmin();
      }

      match /entries/{entryId} {
        allow read: if ownPatient(patientId) || isAdmin();
        allow create, update: if (ownPatient(patientId) || isAdmin()) &&
          request.resource.data.type in ["appointment", "exam"] &&
          request.resource.data.dateTime is timestamp;
        allow delete: if ownPatient(patientId) || isAdmin();
      }
    }
  }
}
